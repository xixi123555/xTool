# xTool MCP Server 环境变量示例
# 复制为 .env 并填入实际值

# xTool Server 地址（默认 localhost:5198）
XTOOL_SERVER_URL=http://localhost:5198

# MCP HTTP 服务端口（必填）
MCP_HTTP_PORT=5197

# MCP HTTP 监听地址（默认 0.0.0.0）
MCP_HTTP_HOST=0.0.0.0

# MCP HTTP 路由路径（默认 /mcp）
MCP_HTTP_PATH=/mcp

# 允许的 Host 列表（逗号分隔，公网部署时建议设置为反代域名）
# MCP_ALLOWED_HOSTS=mcp.example.com,localhost

# MCP Key（推荐，可选，作为后备默认认证）
XTOOL_MCP_KEY=

# JWT Token（兼容保留，可选，作为后备默认认证）
XTOOL_JWT_TOKEN=

# Dify API Key（可选，网页阅读器专用。若不配置且已登录，将尝试从 appkey 获取 web_reader）
DIFY_API_KEY=
